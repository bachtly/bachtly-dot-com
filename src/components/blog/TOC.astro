---
import type { MarkdownHeading } from "astro";
import { generateToc } from "@/utils/generateToc";
import TOCHeading from "./TOCHeading.astro";

interface Props {
	headings: MarkdownHeading[];
}

const { headings } = Astro.props;

// Posts come from GitHub Issue bodies, where an author's `#` is the natural
// top level for a section, so in-body h1s have to count as TOC entries.
const toc = generateToc(headings, { minHeadingLevel: 1 });
---

{
	// A post whose headings all fall outside the TOC's depth range would
	// otherwise render an empty disclosure box.
	toc.length > 0 && (
		<details
			id="toc"
			class="lg:sticky lg:top-12 lg:order-2 lg:max-h-[calc(100vh-6rem)] lg:basis-64 lg:overflow-y-auto"
		>
			<summary class="title hover:marker:text-accent cursor-pointer text-lg">
				Table of Contents
			</summary>
			<nav class="ms-4 lg:w-full">
				<ol class="mt-4">
					{toc.map((heading) => (
						<TOCHeading heading={heading} />
					))}
				</ol>
			</nav>
		</details>
	)
}

<script is:inline>
	// Collapsed by default where the TOC stacks above the article (narrow
	// viewports), expanded where it renders as the side rail.
	if (window.matchMedia("(min-width: 1024px)").matches) {
		const toc = document.getElementById("toc");
		if (toc) toc.open = true;
	}
</script>
